{
  "name": "chat-widget-sendbird",
  "private": false,
  "version": "1.9.2",
  "type": "module",
  "description": "A professional chat widget built with SendBird UI Kit and React",
  "keywords": [
    "chat",
    "widget",
    "sendbird",
    "react",
    "typescript",
    "tailwind"
  ],
  "author": "oleyva93-pro",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/oleyva93-pro/chat-widget-pro.git"
  },
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "style": "dist/style.css",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && npm run build:css",
    "build:lib": "tsc -p tsconfig.lib.json && vite build --config vite.lib.config.ts && npm run copy-types && npm run clean-temp",
    "copy-types": "cp -r dist-temp/* dist/ 2>/dev/null || true",
    "clean-temp": "rm -rf dist-temp",
    "lint": "eslint .",
    "preview": "vite preview",
    "prepublishOnly": "npm run build:lib",
    "build:css": "tailwindcss -i ./src/styles/index.css -o ./dist/style1.css --minify",
    "convert-imports": "node scripts/convert-imports.mjs",
    "fix-imports": "node scripts/fix-remaining-imports.mjs"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@sendbird/chat": "4.22.5",
    "@sendbird/uikit-react": "3.18.0",
    "@tanstack/react-query": "^5.84.1",
    "axios": "^1.11.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.536.0",
    "react-rnd": "^10.5.2",
    "react-tooltip": "^5.29.1",
    "swr": "^2.3.6",
    "tailwind-merge": "^3.3.1",
    "use-debounce": "^10.0.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@types/node": "^24.1.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.6.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.30.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "glob": "^10.4.5",
    "globals": "^16.3.0",
    "postcss": "^8.5.6",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.35.1",
    "vite": "^5.0.0"
  }
}
